# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

DISCORD_TOKEN=your-bot-token-here
SOURCE_FORUM_ID=source-forum-channel-id
DESTINATION_CHANNEL_ID=destination-channel-id

# Optional: comma-separated list of thread IDs to always skip
EXCLUDED_THREAD_IDS=thread-id-1,thread-id-2

# Optional: path to the processed-threads state file
PROCESSED_THREADS_FILE=./processed-threads.yml
